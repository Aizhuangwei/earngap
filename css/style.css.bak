/* ============================================================
   EarnGap v2 · 烁腾云控 — 最终版暗黑科技风
   ============================================================ */

/* ---------- 滚动条 ---------- */
::-webkit-scrollbar { width: 5px; height: 5px; }
::-webkit-scrollbar-track { background: #0A0A0D; }
::-webkit-scrollbar-thumb { background: #2A2A3A; border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: #4ADE80; }
::selection { background: rgba(74, 222, 128, 0.3); color: #fff; }

*, *::before, *::after { box-sizing: border-box; }
body {
  margin: 0; padding: 0;
  background: #0A0A0D;
  color: #d1d5db;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans SC', 'SF Pro', sans-serif;
  font-size: 14px;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
}

/* ===== 顶部导航 ===== */
.topbar {
  display: flex; align-items: center; justify-content: space-between;
  height: 90px; padding: 0 40px;
  background: #0A0A0D;
  border-bottom: 1px solid #1E1E2A;
  position: sticky; top: 0; z-index: 100;
}
.topbar-left { display: flex; align-items: center; gap: 18px; flex-shrink: 0; }
.logo-icon { width: 60px; height: 60px; border-radius: 15px; background: linear-gradient(135deg, #4ADE80, #22D3EE); display: flex; align-items: center; justify-content: center; color: #000; font-weight: 800; font-size: 24px; }
.logo-text { font-size: 30px; font-weight: 700; letter-spacing: -0.5px; }
.topbar-tagline { font-size: 22px; font-weight: 500; color: #e4e6f0; letter-spacing: 2px; white-space: nowrap; }
.topbar-right { display: flex; align-items: center; gap: 20px; }
.lang-switch { display: flex; align-items: center; gap: 6px; font-size: 16px; }
.lang-link { color: #6B6F82; text-decoration: none; font-weight: 600; transition: color 0.2s; padding: 4px 2px; cursor: pointer; }
.lang-link:hover { color: #e4e6f0; }
.lang-link.active { color: #4ADE80; }
.lang-divider { color: #1E1E2A; }
.search-box { display: flex; align-items: center; gap: 12px; background: #121217; border: 2px solid #4ADE80; border-radius: 12px; padding: 10px 18px; transition: border-color 0.2s, box-shadow 0.2s; }
.search-box:focus-within { border-color: #22D3EE; box-shadow: 0 0 12px rgba(74, 222, 128, 0.3); }
.search-icon { color: #e4e6f0; font-size: 16px; }
.search-input { background: none; border: none; outline: none; color: #e4e6f0; font-size: 16px; width: 180px; }
.search-input::placeholder { color: #4B4F62; }

/* ===== 主布局 ===== */
.layout-container { display: flex; min-height: calc(100vh - 90px - 65px); }

/* 左侧导航 */
.left-sidebar { width: 180px; flex-shrink: 0; background: #0A0A0D; border-right: 1px solid #1E1E2A; display: flex; flex-direction: column; justify-content: space-between; display: none; }
@media (min-width: 1024px) { .left-sidebar { display: flex; } }
.sidebar-nav { padding: 16px 10px; display: flex; flex-direction: column; gap: 2px; }
.sidebar-item { display: flex; align-items: center; gap: 10px; padding: 10px 12px; border-radius: 8px; color: #e4e6f0; text-decoration: none; font-size: 18px; font-weight: 500; transition: all 0.2s; cursor: pointer; }
.sidebar-item i { width: 26px; text-align: center; font-size: 18px; }
.sidebar-item:hover { background: rgba(255,255,255,0.03); }
.sidebar-item.active { color: #4ADE80; background: rgba(74, 222, 128, 0.1); }
.sidebar-partners-grid { display: flex; flex-direction: column; gap: 4px; padding: 8px 10px; border-top: 1px solid #1E1E2A; }
.partner-icon { padding: 6px 12px; display: flex; align-items: center; gap: 10px; font-size: 16px; color: #6B6F82; text-decoration: none; border-radius: 6px; transition: all 0.2s; }
.partner-icon:hover { color: #4ADE80; background: rgba(74, 222, 128, 0.08); }
.sidebar-footer { padding: 12px; border-top: 1px solid #1E1E2A; }
.sidebar-online { display: flex; align-items: center; gap: 8px; font-size: 16px; color: #e4e6f0; }
.online-dot { width: 10px; height: 10px; border-radius: 50%; background: #4ADE80; box-shadow: 0 0 8px rgba(74, 222, 128, 0.4); animation: pulse-dot 2s infinite; }
@keyframes pulse-dot { 0%,100% { box-shadow: 0 0 8px rgba(74, 222, 128, 0.4); } 50% { box-shadow: 0 0 14px rgba(74, 222, 128, 0.7); } }

/* 主内容区 */
.main-area { flex: 1; padding: 20px 24px; overflow-y: auto; max-width: 100%; }

/* ===== 页面切换 ===== */
.page-hidden { display: none !important; }

/* ===== 数据概览区 ===== */
.overview-section { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px; margin-bottom: 20px; }
.overview-card { background: #121217; border: 1px solid #1E1E2A; border-radius: 12px; padding: 22px 20px; transition: all 0.25s ease; text-align: center; }
.overview-card:hover { border-color: rgba(74, 222, 128, 0.25); box-shadow: 0 0 20px rgba(74, 222, 128, 0.05); transform: translateY(-1px); }
.overview-label { font-size: 20px; color: #e4e6f0; font-weight: 500; margin-bottom: 8px; letter-spacing: 0.3px; }
.overview-value { font-size: 36px; font-weight: 700; color: #e4e6f0; font-variant-numeric: tabular-nums; line-height: 1.1; margin-bottom: 6px; }
.overview-value.accent-green { color: #4ADE80; }
.overview-value.accent-cyan { color: #22D3EE; }
.overview-value.accent-yellow { color: #FBBF24; }
.overview-value.accent-red { color: #e4e6f0; }
.overview-change { font-size: 20px; font-weight: 500; display: flex; align-items: center; justify-content: center; gap: 4px; }
.overview-change.up .change-val { color: #4ADE80; }
.overview-change.down .change-val { color: #EF4444; }
.overview-change.neutral .change-val { color: #e4e6f0; }
.change-label { color: #e4e6f0; }

/* ===== Top 3 ===== */
.top3-section { margin-bottom: 20px; }
.section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 14px; }
.section-header h2 { font-size: 30px; font-weight: 700; color: #e4e6f0; margin: 0; display: flex; align-items: center; gap: 8px; }
.section-more { font-size: 18px; color: #e4e6f0; text-decoration: none; transition: color 0.2s; display: flex; align-items: center; gap: 4px; cursor: pointer; }
.section-more:hover { color: #4ADE80; }
.top3-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 12px; }
.top3-card { background: #121217; border: 1px solid #1E1E2A; border-radius: 10px; padding: 18px; transition: all 0.25s ease; position: relative; overflow: hidden; }
.top3-card::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 8px; }
.top3-card.rank-1::before { background: linear-gradient(90deg, #FBBF24, #F59E0B); }
.top3-card.rank-2::before { background: linear-gradient(90deg, #94A3B8, #6B7280); }
.top3-card.rank-3::before { background: linear-gradient(90deg, #D97706, #B45309); }
.top3-card:hover { transform: translateY(-2px); box-shadow: 0 4px 20px rgba(74, 222, 128, 0.08); }
.top3-rank { display: inline-flex; align-items: center; justify-content: center; width: 46px; height: 46px; border-radius: 10px; font-size: 30px; font-weight: 700; margin-bottom: 8px; }
.rank-1 .top3-rank { background: rgba(251, 191, 36, 0.15); color: #FBBF24; }
.rank-2 .top3-rank { background: rgba(148, 163, 184, 0.15); color: #94A3B8; }
.rank-3 .top3-rank { background: rgba(217, 119, 6, 0.15); color: #D97706; }
.top3-title { font-size: 18px; font-weight: 600; color: #e4e6f0; margin-bottom: 8px; line-height: 1.4; }
.top3-tags { display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 8px; }
.tag { font-size: 14px; padding: 3px 10px; border-radius: 5px; font-weight: 500; }
.tag-green { background: rgba(74, 222, 128, 0.1); color: #4ADE80; }
.tag-cyan { background: rgba(34, 211, 238, 0.1); color: #22D3EE; }
.tag-yellow { background: rgba(251, 191, 36, 0.1); color: #FBBF24; }
.tag-red { background: rgba(239, 68, 68, 0.1); color: #EF4444; }
.tag-gray { background: rgba(107, 111, 130, 0.1); color: #e4e6f0; }
.tag-new { background: rgba(74, 222, 128, 0.2); color: #4ADE80; font-weight: 700; animation: pulse-tag 2s infinite; }
@keyframes pulse-tag { 0%,100% { opacity: 1; } 50% { opacity: 0.6; } }
.top3-score { font-size: 30px; font-weight: 700; color: #4ADE80; }
.top3-status { font-size: 18px; color: #e4e6f0; margin-top: 4px; }

/* ===== 广告位 ===== */
.ad-section { margin-bottom: 20px; }
.ad-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
@media (max-width: 640px) { .ad-grid { grid-template-columns: repeat(2, 1fr); } }
.ad-card { background: linear-gradient(135deg, rgba(74, 222, 128, 0.05), rgba(34, 211, 238, 0.05)); border: 2px solid rgba(74, 222, 128, 0.4); border-radius: 10px; padding: 16px; text-align: center; transition: all 0.25s ease; cursor: pointer; min-height: 130px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 6px; }
.ad-card:hover { border-color: rgba(74, 222, 128, 0.6); box-shadow: 0 0 20px rgba(74, 222, 128, 0.15); transform: translateY(-2px); }
.ad-card i { font-size: 24px; color: #4ADE80; }
.ad-card .ad-title { font-size: 14px; font-weight: 600; color: #e4e6f0; }
.ad-card .ad-sub { font-size: 11px; color: #e4e6f0; }

/* ===== 筛选区 ===== */
.filter-section { display: flex; flex-wrap: wrap; align-items: flex-end; gap: 16px; margin-bottom: 24px; background: #121217; border: 1px solid #1E1E2A; border-radius: 14px; padding: 22px 24px; }
.filter-group { display: flex; flex-direction: column; gap: 4px; align-items: flex-start; }
.filter-group label { font-size: 20px; color: #e4e6f0; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
.filter-group select { background: #0A0A0D; border: 1px solid #1E1E2A; border-radius: 6px; padding: 6px 10px; color: #d1d5db; font-size: 20px; outline: none; cursor: pointer; min-width: 110px; }
.filter-group select:focus { border-color: rgba(74, 222, 128, 0.4); }
.filter-btn { padding: 6px 16px; background: linear-gradient(135deg, #4ADE80, #22D3EE); border: none; border-radius: 8px; color: #000; font-size: 14px; font-weight: 600; cursor: pointer; display: flex; align-items: center; gap: 6px; transition: opacity 0.2s; height: 32px; align-self: flex-end; }
.filter-btn:hover { opacity: 0.9; }

/* ===== 机会面板 ===== */
.main-content { display: flex; flex-direction: column; gap: 12px; }
.opp-panel { background: #121217; border: 1px solid #1E1E2A; border-radius: 10px; overflow: hidden; transition: border-color 0.2s; }
.opp-panel:hover { border-color: rgba(74, 222, 128, 0.15); }
.opp-panel-header { display: flex; align-items: center; justify-content: space-between; padding: 22px 24px; cursor: pointer; user-select: none; transition: background 0.2s; }
.opp-panel-header:hover { background: rgba(255,255,255,0.02); }
.opp-panel-title { display: flex; align-items: center; gap: 10px; flex: 1; min-width: 0; }
.opp-panel-name { font-size: 16px; font-weight: 600; color: #e4e6f0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.opp-panel-score { font-size: 16px; font-weight: 700; color: #4ADE80; flex-shrink: 0; }
.opp-panel-toggle { color: #e4e6f0; font-size: 18px; transition: transform 0.3s; flex-shrink: 0; margin-left: 8px; }
.opp-panel.expanded .opp-panel-toggle { transform: rotate(180deg); }
.opp-panel-body { max-height: 0; overflow: hidden; transition: max-height 1.85s ease; }
.opp-panel.expanded .opp-panel-body { max-height: 2000px; }
.opp-panel-inner { padding: 0 24px 24px 24px; border-top: 1px solid #1E1E2A; padding-top: 20px; }
.opp-description { font-size: 14px; color: #e4e6f0; line-height: 1.6; margin-bottom: 20px; }
.opp-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 20px; }
.score-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px 28px; margin-bottom: 20px; }
@media (min-width: 640px) { .score-grid { grid-template-columns: 1fr 1fr 1fr 1fr; } }
.score-item { display: flex; flex-direction: column; gap: 6px; }
.score-label { font-size: 18px; color: #e4e6f0; display: flex; justify-content: space-between; }
.score-bar-track { height: 6px; background: #1E1E2A; border-radius: 3px; overflow: hidden; }
.score-bar-fill { height: 100%; border-radius: 3px; transition: width 0.6s ease; }
.decision-section { margin-bottom: 20px; }
.decision-section-title { font-size: 14px; font-weight: 600; color: #4ADE80; margin-bottom: 8px; display: flex; align-items: center; gap: 8px; }
.decision-item { font-size: 14px; color: #d1d5db; padding: 6px 0; display: flex; align-items: flex-start; gap: 8px; }
.decision-item i { color: #4ADE80; font-size: 16px; margin-top: 4px; }
.path-section-title { font-size: 14px; font-weight: 600; color: #22D3EE; margin-bottom: 8px; display: flex; align-items: center; gap: 8px; }
.path-steps { display: flex; flex-wrap: wrap; gap: 10px; }
.path-step { font-size: 18px; padding: 6px 16px; background: rgba(34, 211, 238, 0.06); border: 1px solid rgba(34, 211, 238, 0.15); border-radius: 6px; color: #22D3EE; }
.path-step i { margin-right: 4px; }

/* ===== 右侧信息区 ===== */
.right-sidebar { width: 350px; flex-shrink: 0; background: #0A0A0D; border-left: 1px solid #1E1E2A; padding: 18px 16px; overflow-y: auto; display: none; }
@media (min-width: 1280px) { .right-sidebar { display: block; } }
.widget { margin-bottom: 18px; }
.widget-title { font-size: 18px; font-weight: 600; color: #e4e6f0; text-transform: uppercase; letter-spacing: 0.5px; margin: 0 0 10px 0; display: flex; align-items: center; gap: 6px; }
.alert-list { display: flex; flex-direction: column; gap: 6px; }
.alert-item { display: flex; align-items: flex-start; gap: 8px; padding: 8px 10px; background: rgba(239, 68, 68, 0.05); border: 1px solid rgba(239, 68, 68, 0.1); border-radius: 6px; font-size: 18px; }
.alert-item .alert-dot { width: 6px; height: 6px; border-radius: 50%; background: #EF4444; flex-shrink: 0; margin-top: 3px; }
.alert-item .alert-text { color: #d1d5db; line-height: 1.4; }
.alert-item .alert-time { color: #e4e6f0; font-size: 10px; margin-top: 2px; }
.pie-chart-container { display: flex; align-items: center; gap: 12px; }
#pie-chart { flex-shrink: 0; }
.pie-legend { display: flex; flex-direction: column; gap: 4px; }
.pie-legend-item { display: flex; align-items: center; gap: 6px; font-size: 14px; color: #e4e6f0; }
.pie-legend-dot { width: 12px; height: 12px; border-radius: 50%; flex-shrink: 0; }
.bar-chart { display: flex; flex-direction: column; gap: 6px; }
.bar-item { display: flex; align-items: center; gap: 8px; }
.bar-item .bar-label { font-size: 12px; color: #e4e6f0; min-width: 64px; flex-shrink: 0; }
.bar-item .bar-track { flex: 1; height: 8px; background: #1E1E2A; border-radius: 3px; overflow: hidden; }
.bar-item .bar-fill { height: 100%; border-radius: 3px; transition: width 0.6s ease; }
.bar-item .bar-value { font-size: 11px; color: #d1d5db; font-weight: 600; min-width: 24px; text-align: right; font-variant-numeric: tabular-nums; }
.scan-log { display: flex; flex-direction: column; gap: 4px; max-height: 180px; overflow-y: auto; }
.scan-entry { display: flex; gap: 6px; font-size: 12px; font-family: 'SF Mono', 'Cascadia Code', monospace; padding: 3px 0; border-bottom: 1px solid rgba(255,255,255,0.02); }
.scan-entry .scan-time { color: #4ADE80; min-width: 60px; flex-shrink: 0; }
.scan-entry .scan-source { color: #22D3EE; min-width: 56px; flex-shrink: 0; }
.scan-entry .scan-msg { color: #e4e6f0; }

/* ===== 页脚 ===== */
.site-footer { display: flex; align-items: center; justify-content: center; height: auto; min-height: 65px; padding: 12px 24px; background: #0A0A0D; border-top: 1px solid #1E1E2A; font-size: 18px; color: #e4e6f0; position: relative; }
.footer-subscribe { position: absolute; right: 24px; bottom: 12px; display: flex; gap: 4px; }
.subscribe-input { background: #121217; border: 2px solid #4ADE80; border-radius: 8px; padding: 8px 14px; color: #e4e6f0; font-size: 18px; outline: none; width: 240px; }
.subscribe-input:focus { border-color: #22D3EE; box-shadow: 0 0 10px rgba(74, 222, 128, 0.3); }
.subscribe-input::placeholder { color: #4ADE80; opacity: 0.5; }
.subscribe-btn { padding: 5px 12px; background: linear-gradient(135deg, #4ADE80, #22D3EE); border: none; border-radius: 6px; color: #000; font-size: 18px; font-weight: 600; cursor: pointer; }
.subscribe-btn:hover { opacity: 0.9; }
.footer-center-wrapper { display: flex; flex-direction: column; align-items: center; gap: 4px; margin-right: 200px; }
.footer-links { display: flex; gap: 14px; }
.footer-links a { color: #e4e6f0; text-decoration: none; transition: color 0.2s; }
.footer-links a:hover { color: #4ADE80; }
.footer-disclaimer { font-size: 18px; color: #e4e6f0; }

/* ===== Coming Soon ===== */
.coming-soon { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 60px 20px; text-align: center; }

/* ===== 方法论/关于 ===== */
.method-content, .about-content { display: flex; flex-direction: column; gap: 24px; }
.method-section { background: #121217; border: 1px solid #1E1E2A; border-radius: 10px; padding: 20px; }
.method-section h3 { font-size: 20px; font-weight: 600; color: #4ADE80; margin: 0 0 10px 0; }
.method-section p { font-size: 14px; color: #d1d5db; line-height: 1.6; margin: 0; }

/* ===== Discover Feed ===== */
.discover-feed { display: flex; flex-direction: column; gap: 8px; }
.discover-item { display: flex; align-items: center; gap: 12px; padding: 12px 16px; background: #121217; border: 1px solid #1E1E2A; border-radius: 8px; font-size: 13px; transition: background 0.2s; }
.discover-item:hover { background: rgba(74, 222, 128, 0.04); }
.discover-item .disc-source { color: #22D3EE; font-weight: 600; min-width: 80px; }
.discover-item .disc-signal { color: #d1d5db; flex: 1; }
.discover-item .disc-score { color: #4ADE80; font-weight: 700; }
.discover-item .disc-time { color: #6B6F82; font-size: 11px; min-width: 60px; text-align: right; }

/* ===== 动画 ===== */
@keyframes fadeInUp { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
.overview-section > *, .top3-grid > *, .opp-panel { animation: fadeInUp 0.35s ease forwards; }
.overview-section > *:nth-child(2) { animation-delay: 0.04s; }
.overview-section > *:nth-child(3) { animation-delay: 0.08s; }
.overview-section > *:nth-child(4) { animation-delay: 0.12s; }
.overview-section > *:nth-child(5) { animation-delay: 0.16s; }
